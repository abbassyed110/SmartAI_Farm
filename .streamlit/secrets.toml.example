# Streamlit Secrets Configuration Template
# 
# For local development:
# 1. Create a file at: .streamlit/secrets.toml
# 2. Add your configuration (see below)
# 3. This file is NOT tracked by git for security
#
# For Streamlit Cloud deployment:
# 1. Go to your app's Advanced Settings
# 2. Scroll to "Secrets"
# 3. Paste the content below and update values

# Backend Flask API URL
# Local: "http://127.0.0.1:5000"
# Production: "https://your-flask-app.herokuapp.com" or your custom domain
BACKEND_URL = "http://127.0.0.1:5000"

# Optional: Database connection string (if using separate DB service)
# DATABASE_URL = "postgresql://user:password@host/database"

# Optional: API keys for external services
# WEATHER_API_KEY = "your-api-key-here"
# MARKET_API_KEY = "your-api-key-here"
